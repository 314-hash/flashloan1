{
  "name": "flashloan-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Flash Loan AI Arbitrage Platform",
  "workspaces": [
    "apps/*",
    "bots/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate --workspace=packages/shared",
    "dev:all": "concurrently \"npm run dev --workspace=packages/shared\" \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=bots/price-scanner\" \"npm run dev --workspace=apps/dashboard\"",
    "dev:infra": "docker-compose -f docker/docker-compose.yml up -d",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:scanner": "npm run dev --workspace=bots/price-scanner",
    "dev:dashboard": "npm run dev --workspace=apps/dashboard",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
