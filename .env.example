# Environment Variables — FlashLoan AI
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Docker default shown below)
# In production, use a strong password and a managed DB (e.g. Supabase, RDS)
DATABASE_URL="postgresql://postgres:password@localhost:5432/flashloan_db?schema=public"

# ─────────────────────────────────────────────────────────────────────────────
# RPC ENDPOINTS
# ─────────────────────────────────────────────────────────────────────────────
# Public endpoints are provided as defaults for quick testing.
# ⚠️  STRONGLY RECOMMENDED: Replace with private endpoints from Alchemy or
#     QuickNode for production use. Public nodes are rate-limited and slow.
#
#   Alchemy:   https://dashboard.alchemy.com/
#   QuickNode: https://www.quicknode.com/
#   Infura:    https://infura.io/

RPC_ETH="https://cloudflare-eth.com"
# RPC_ETH="https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

RPC_ARBITRUM="https://arb1.arbitrum.io/rpc"
# RPC_ARBITRUM="https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

RPC_POLYGON="https://polygon-rpc.com"
# RPC_POLYGON="https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

RPC_BASE="https://mainnet.base.org"
# RPC_BASE="https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

RPC_OPTIMISM="https://mainnet.optimism.io"
# RPC_OPTIMISM="https://opt-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

# ─────────────────────────────────────────────────────────────────────────────
# API SERVER
# ─────────────────────────────────────────────────────────────────────────────

# Port the Express API server listens on
PORT=4000

# Full URL of the API (used by the dashboard)
API_URL="http://localhost:4000"

# ─────────────────────────────────────────────────────────────────────────────
# BOT CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# How often the scanner checks prices (milliseconds)
# Lower = more real-time but higher RPC usage
SCAN_INTERVAL_MS=5000

# Minimum net profit (USD) for an opportunity to be flagged as DETECTED
# Opportunities below this are logged as SIMULATED
MIN_PROFIT_THRESHOLD_USD=10.0

# Paper trading mode — set to false ONLY when you are ready for live execution
# with a deployed and audited flash loan smart contract
PAPER_TRADING=true

# ─────────────────────────────────────────────────────────────────────────────
# FUTURE / OPTIONAL (uncomment when implementing live execution)
# ─────────────────────────────────────────────────────────────────────────────

# Executor contract address (deployed flash loan arbitrage contract)
# EXECUTOR_CONTRACT_ADDRESS=""

# Private key for the execution wallet (USE KMS IN PRODUCTION — NOT .env)
# EXECUTOR_PRIVATE_KEY=""

# Flashbots relay URL (for MEV-protected bundle submission)
# FLASHBOTS_RELAY_URL="https://relay.flashbots.net"
