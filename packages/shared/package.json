{
  "name": "@flashloan/shared",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsc --watch",
    "build": "npm run db:generate && tsc",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:push": "dotenv -e ../../.env prisma db push --schema=./prisma/schema.prisma",
    "db:migrate": "dotenv -e ../../.env prisma migrate dev --schema=./prisma/schema.prisma",
    "db:studio": "dotenv -e ../../.env prisma studio --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.10.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
